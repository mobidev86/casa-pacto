{
    "tabWidth": 4,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "all",
    "tailwindStylesheet": "./resources/site/site.css",
    "plugins": ["prettier-plugin-antlers", "prettier-plugin-tailwindcss"],
    "overrides": [
        {
            "files": ["*.antlers.html"],
            "options": {
                "parser": "antlers"
            }
        }
    ]
}
